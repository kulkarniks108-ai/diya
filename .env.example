# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=2ndEye API
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random key for production: openssl rand -hex 32
SECRET_KEY=replace-with-a-strong-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# When using Docker Compose, the API connects to the DB via the "db" hostname.
# If running API natively (without Docker), change DB_HOST to localhost.
DB_HOST=db
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=replace-with-your-db-password
DB_NAME=secondeye_dev

# ── Observability ─────────────────────────────────────────────────────────────
LOG_FORMAT=pretty    # pretty (dev) | json (staging/production)
LOG_LEVEL=INFO

# ── Providers (leave blank until the module is active) ────────────────────────
GEMINI_API_KEY=
FCM_CREDENTIALS_PATH=
